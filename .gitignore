next-kyudo-api/__pycache__/
next-kyudo-api/.pytest_cache/
next-kyudo-api/*.pyc

# ★絶対にGitHubに上げてはいけないFirebaseの秘密鍵
next-kyudo-api/serviceAccountKey.json

