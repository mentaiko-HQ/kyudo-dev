next-kyudo-app/node_modules/
next-kyudo-app/.next/
next-kyudo-app/out/
next-kyudo-app/build/
next-kyudo-app/.env.local
next-kyudo-app/.env.development.local
next-kyudo-app/.env.test.local
next-kyudo-app/.env.production.local

# ==========================================
# バックエンド (next-kyudo-api) 用の除外設定
# ==========================================
